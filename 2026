function renderLeaderboard(){
  const rows=profiles.map(p=>({...p,...userTotals(p.id)}))
    .sort((a,b)=> b.pts-a.pts || b.exact-a.exact || a.username.localeCompare(b.username));
  const box=$("#leaderboard");
  if(!rows.length){ box.innerHTML=`<div style="padding:24px;text-align:center;color:var(--muted)">Henüz oyuncu yok.</div>`; return; }
  box.innerHTML=rows.map((r,i)=>{
    const rank=i+1, gcls=rank<=3?`g${rank}`:"";
    const medal=rank===1?"🥇":rank===2?"🥈":rank===3?"🥉":rank;
    const meCls=r.id===session.user.id?"me":"";
    return `<div class="lbrow ${meCls}" data-uid="${r.id}">
      <div class="rank ${gcls}">${medal}</div>
      <div class="lbav">${esc(initials(r.username))}</div>
      <div class="lbinfo"><div class="nm">${esc(r.username)}${r.is_admin?' ⚙️':''}</div>
        <div class="st"><span class="e">${r.exact} tam</span> · <span class="o">${r.outc} sonuç</span> · ${r.graded} maç</div></div>
      <div class="lbpts">${r.pts}<small>PUAN</small></div>
    </div>`;
  }).join("");
  box.querySelectorAll(".lbrow").forEach(el=>el.onclick=()=>openProfile(el.dataset.uid));
}
function openProfile(uid){
  const prof=profiles.find(p=>p.id===uid); if(!prof) return;
  const t=userTotals(uid);
  const byMatch={}; predsAll.forEach(p=>{ if(p.user_id===uid) byMatch[p.match_id]=p; });
  const finished=matches.filter(m=>m.finished);

  const rows=finished.map(m=>{
    const pred=byMatch[m.id]||null;
    const g=grade(pred,m);
    const cls=g.type;
    const predTxt = pred?`${pred.home}–${pred.away}`:"—";
    const ptTxt = g.type==="exact"?"+100":g.type==="outc"?"+30":"0";
    const stageTxt = m.grp?`Grup ${m.grp}`:(m.label||STAGE_LABEL[m.stage]);
    return `<div class="pg ${cls}">
      <div class="aa">${m.home_score}–${m.away_score}</div>
      <div class="mt">${esc(trName(m.team_home))} - ${esc(trName(m.team_away))}<br><small>${esc(stageTxt)}</small></div>
      <div class="pp">${predTxt}</div>
      <div class="pt">${ptTxt}</div>
    </div>`;
  }).join("");

  $("#modalCard").innerHTML=`
    <div class="mh"><div class="av">${esc(initials(prof.username))}</div>
      <div><h3>${esc(prof.username)}</h3>
        <div class="s">${t.pts} puan · ${t.exact} tam skor · ${t.outc} doğru sonuç · ${t.graded} maç</div></div>
      <button class="x" id="mClose">✕</button></div>
    <div class="legend">
      <span><i class="lg-e"></i> Skoru tam bildi (+100)</span>
      <span><i class="lg-o"></i> Sonucu bildi (+30)</span>
      <span><i class="lg-b"></i> Bilemedi (0)</span>
    </div>
    <div class="pgrid">${rows||'<div class="empty">Henüz biten maç yok.</div>'}</div>`;
  $("#modal").classList.add("show");
  $("#mClose").onclick=closeModal;
}
function closeModal(){ $("#modal").classList.remove("show"); }

/* ====================================================================
   11) RIBBON (canlı/biten skor şeridi)
   ==================================================================== */
function renderRibbon(){
  const done=matches.filter(m=>m.finished).slice(-14);
  const items = done.length?done:matches.filter(m=>m.team_home&&m.team_away).slice(0,14);
  const cell=m=>{
    if(m.finished) return `<span class="it">${esc(trName(m.team_home))} <b>${m.home_score}-${m.away_score}</b> ${esc(trName(m.team_away))}</span>`;
    return `<span class="it">${esc(trName(m.team_home))} <b>vs</b> ${esc(trName(m.team_away))} · ${fmtKick(m.kickoff)}</span>`;
  };
  const seq=items.map(cell).join("");
  $("#ribbonTrack").innerHTML = seq+seq; // kesintisiz döngü için iki kez
}

/* ====================================================================
   12) YÖNETİM PANELİ
   ==================================================================== */
function renderAdminFilters(){
  const present=new Set(matches.map(m=>m.stage));
  $("#adminStageFilters").innerHTML = STAGES.filter(s=>present.has(s.k)).map(s=>
    `<button class="pill ${s.k===adminStage?"on":""}" data-stage="${s.k}">${s.label}</button>`).join("");
  $("#adminStageFilters").querySelectorAll(".pill").forEach(b=>b.onclick=()=>{
    adminStage=b.dataset.stage; renderAdminFilters(); renderAdmin();
  });
}
function renderAdmin(){
  const box=$("#adminList");
  const ms=matches.filter(m=>m.stage===adminStage);
  box.innerHTML=ms.map(m=>{
    const label=m.grp?`Grup ${m.grp}`:(m.label||STAGE_LABEL[m.stage]);
    const teamset = (m.stage!=="group") ? `
      <div class="teamset">
        <input class="tin" data-id="${m.id}" data-f="team_home" placeholder="${esc(m.slot_home||'Ev sahibi (İngilizce)')}" value="${esc(m.team_home||'')}">
        <input class="tin" data-id="${m.id}" data-f="team_away" placeholder="${esc(m.slot_away||'Deplasman (İngilizce)')}" value="${esc(m.team_away||'')}">
      </div>`:"";
    const hn=m.team_home?trName(m.team_home):(m.slot_home||"?");
    const an=m.team_away?trName(m.team_away):(m.slot_away||"?");
    return `<div style="margin-bottom:8px">
      <div style="font-size:11px;color:var(--muted);font-weight:700;margin:0 2px 4px">${esc(label)} · ${fmtKick(m.kickoff)}</div>
      ${teamset}
      <div class="arow">
        <div class="nm">${esc(hn)}</div>
        <input data-id="${m.id}" data-f="home_score" type="number" min="0" value="${m.home_score??""}">
        <div style="text-align:center;color:var(--muted)">–</div>
        <input data-id="${m.id}" data-f="away_score" type="number" min="0" value="${m.away_score??""}">
        <button class="btn gold sm" data-save="${m.id}">Kaydet</button>
      </div>
      <div style="text-align:right;font-size:11px;color:var(--muted);margin:2px 4px 0">${esc(an)}</div>
    </div>`;
  }).join("");
  box.querySelectorAll("[data-save]").forEach(btn=>btn.onclick=()=>adminSave(+btn.dataset.save,btn));
}
async function adminSave(id,btn){
  const get=f=>{const el=$(`[data-id="${id}"][data-f="${f}"]`);return el?el.value.trim():null;};
  const hs=get("home_score"), as=get("away_score");
  const th=get("team_home"), ta=get("team_away");
  const patch={};
  if(th!==null) patch.team_home = th||null;
  if(ta!==null) patch.team_away = ta||null;
  if(hs!==""&&hs!=null && as!==""&&as!=null){
    patch.home_score=parseInt(hs,10); patch.away_score=parseInt(as,10); patch.finished=true;
  }else{
    patch.home_score=null; patch.away_score=null; patch.finished=false;
  }
  btn.disabled=true; btn.textContent="…";
  try{
    const {error}=await sb.from("matches").update(patch).eq("id",id);
    if(error) throw error;
    Object.assign(matches.find(m=>m.id===id),patch);
    band("Maç güncellendi","Yönetim");
    renderLeaderboard(); renderRibbon();
  }catch(err){ band((err&&err.message)||"Hata","Yönetim",true); }
  finally{ btn.disabled=false; btn.textContent="Kaydet"; }
}

/* ====================================================================
   13) TAB yönetimi + boot
   ==================================================================== */
function switchTab(t){
  document.querySelectorAll("nav.tabs button").forEach(b=>b.classList.toggle("on",b.dataset.tab===t));
  show($("#tab-matches"),t==="matches");
  show($("#tab-how"),t==="how");
  show($("#tab-admin"),t==="admin");
  if(t==="admin"){ renderAdminFilters(); renderAdmin(); }
}
function renderAll(){
  renderRibbon(); renderStageFilters(); renderGroupFilters(); renderMatches(); renderLeaderboard();
}
async function enterApp(){
  show($("#authScreen"),false); show($("#setupScreen"),false); show($("#appScreen"),true);
  $("#meName").textContent=me.username;
  $("#meAv").textContent=initials(me.username);
  show($("#adminTab"),!!me.is_admin);
  await loadAll();
  renderAll();
}

function bindStaticUI(){
  $("#auBtn").onclick=doAuth;
  $("#auPass").addEventListener("keydown",e=>{ if(e.key==="Enter") doAuth(); });
  setRegister(false);
  $("#logoutBtn").onclick=async()=>{ await sb.auth.signOut(); location.reload(); };
  $("#refreshBtn").onclick=async()=>{ await loadAll(); renderAll(); if(me.is_admin)renderAdmin(); band("Güncel veriler yüklendi","Yenilendi"); };
  document.querySelectorAll("nav.tabs button").forEach(b=>b.onclick=()=>switchTab(b.dataset.tab));
  $("#modal").addEventListener("click",e=>{ if(e.target.id==="modal") closeModal(); });
  document.addEventListener("keydown",e=>{ if(e.key==="Escape") closeModal(); });
}

async function boot(){
  if(SUPABASE_URL.includes("YOUR-PROJECT") || SUPABASE_ANON_KEY.includes("YOUR-ANON")){
    show($("#setupScreen"),true); return;
  }
  sb=supabase.createClient(SUPABASE_URL,SUPABASE_ANON_KEY);
  bindStaticUI();
  const {data:{session:s}}=await sb.auth.getSession();
  session=s;
  if(session){ await loadProfile(); await enterApp(); }
  else show($("#authScreen"),true);
  sb.auth.onAuthStateChange(async(_e,s2)=>{
    if(s2 && (!session || s2.user.id!==session.user.id)){
      session=s2; await loadProfile(); await enterApp();
    }else if(!s2){ session=null; }
  });
}
boot();
</script>
</body>
</html>

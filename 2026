<!DOCTYPE html>
<html lang="tr">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Dünya Kupası 2026 — Tahmin Ligi</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Anton&family=Plus+Jakarta+Sans:wght@400;500;600;700;800&display=swap" rel="stylesheet">
<link rel="icon" href="data:image/svg+xml,%3Csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 100 100'%3E%3Ctext y='.9em' font-size='90'%3E%F0%9F%8F%86%3C/text%3E%3C/svg%3E">
<script src="https://cdn.jsdelivr.net/npm/@supabase/supabase-js@2"></script>
<style>
:root{
  --bg:#091310; --bg2:#0b1a14; --panel:#0f2419; --panel2:#0c1d15;
  --line:rgba(255,255,255,.08); --line2:rgba(255,255,255,.14);
  --gold:#f5c542; --gold2:#ffe08a;
  --ok:#2bd575; --okdim:#14361f; --outc:#46b6ff; --outcdim:#10293b;
  --bad:#ff5160; --baddim:#3a141a; --energy:#ff5a3c;
  --ink:#eef6ef; --muted:#84a395;
  --r:16px;
}
*{box-sizing:border-box}
html,body{margin:0;padding:0}
body{
  background:
    radial-gradient(1200px 600px at 80% -10%, rgba(245,197,66,.10), transparent 60%),
    radial-gradient(900px 500px at -10% 10%, rgba(43,213,117,.10), transparent 55%),
    var(--bg);
  color:var(--ink);
  font-family:'Plus Jakarta Sans',system-ui,sans-serif;
  -webkit-font-smoothing:antialiased;
  min-height:100vh;
}
h1,h2,h3,.disp{font-family:'Anton',sans-serif;font-weight:400;letter-spacing:.5px;text-transform:uppercase}
button{font-family:inherit;cursor:pointer}
input{font-family:inherit}
a{color:var(--gold)}

/* ===== TOP RIBBON TICKER ===== */
#ribbon{position:sticky;top:0;z-index:40;background:linear-gradient(90deg,#0a1611,#0e2218,#0a1611);
  border-bottom:1px solid var(--line);overflow:hidden;height:34px;display:flex;align-items:center}
#ribbon .tag{flex:0 0 auto;background:var(--energy);color:#1a0a06;font-weight:800;font-size:11px;
  letter-spacing:1px;padding:5px 10px;height:34px;display:flex;align-items:center;text-transform:uppercase}
#ribbon .track{display:flex;gap:30px;white-space:nowrap;animation:scroll 60s linear infinite;padding-left:30px}
#ribbon .track:hover{animation-play-state:paused}
#ribbon .it{font-size:12.5px;color:#cfe3d6;font-weight:600;display:inline-flex;gap:8px;align-items:center}
#ribbon .it b{font-family:'Anton';font-weight:400;color:var(--gold);font-size:14px;letter-spacing:1px}
@keyframes scroll{from{transform:translateX(0)}to{transform:translateX(-50%)}}
@media(prefers-reduced-motion:reduce){#ribbon .track{animation:none}}

/* ===== HEADER ===== */
header.app{max-width:1180px;margin:0 auto;padding:22px 20px 6px;display:flex;align-items:center;gap:16px;flex-wrap:wrap}
.brand{display:flex;align-items:center;gap:12px}
.brand .trophy{width:46px;height:46px;border-radius:12px;display:grid;place-items:center;font-size:24px;
  background:linear-gradient(160deg,#1c3a28,#0c1d15);border:1px solid var(--line2);
  box-shadow:0 6px 22px rgba(0,0,0,.4), inset 0 1px 0 rgba(255,255,255,.06)}
.brand h1{margin:0;font-size:26px;line-height:.95;color:var(--ink)}
.brand h1 .y{color:var(--gold)}
.brand .sub{font-size:11.5px;letter-spacing:2px;color:var(--muted);font-weight:700;text-transform:uppercase;margin-top:3px}
.spacer{flex:1}
.userchip{display:flex;align-items:center;gap:10px;background:var(--panel);border:1px solid var(--line);
  border-radius:999px;padding:6px 6px 6px 14px}
.userchip .nm{font-weight:700;font-size:14px}
.userchip .av{width:30px;height:30px;border-radius:50%;background:linear-gradient(160deg,var(--gold),#b8860b);
  color:#241400;display:grid;place-items:center;font-weight:800;font-size:14px}
.btn{border:1px solid var(--line2);background:#13261c;color:var(--ink);border-radius:10px;padding:9px 14px;font-weight:700;font-size:13.5px}
.btn:hover{background:#173024}
.btn.gold{background:linear-gradient(160deg,var(--gold),#d9a91f);color:#241400;border:none}
.btn.gold:hover{filter:brightness(1.06)}
.btn.ghost{background:transparent}
.btn.sm{padding:6px 10px;font-size:12.5px}

/* ===== TABS ===== */
nav.tabs{max-width:1180px;margin:14px auto 0;padding:0 20px;display:flex;gap:6px;border-bottom:1px solid var(--line)}
nav.tabs button{background:none;border:none;color:var(--muted);font-weight:700;font-size:14px;padding:12px 14px;
  border-bottom:2px solid transparent;margin-bottom:-1px}
nav.tabs button.on{color:var(--ink);border-color:var(--gold)}
nav.tabs button:hover{color:var(--ink)}

/* ===== LAYOUT ===== */
.wrap{max-width:1180px;margin:18px auto 90px;padding:0 20px;display:grid;grid-template-columns:1fr 348px;gap:22px;align-items:start}
@media(max-width:900px){.wrap{grid-template-columns:1fr}}
.col-right{position:sticky;top:46px}
@media(max-width:900px){.col-right{position:static}}

/* ===== FILTER PILLS ===== */
.filters{display:flex;gap:7px;flex-wrap:wrap;margin-bottom:14px}
.pill{background:var(--panel);border:1px solid var(--line);color:var(--muted);border-radius:999px;
  padding:7px 13px;font-size:12.5px;font-weight:700}
.pill.on{background:var(--gold);color:#241400;border-color:var(--gold)}
.pill:hover{color:var(--ink)}
.pill.on:hover{color:#241400}

/* ===== MATCH CARD ===== */
.daygroup{margin-bottom:8px}
.dayhdr{font-family:'Anton';font-size:13px;letter-spacing:2px;color:var(--gold);margin:18px 2px 10px}
.match{background:linear-gradient(180deg,var(--panel),var(--panel2));border:1px solid var(--line);
  border-radius:var(--r);padding:14px 16px;margin-bottom:11px;position:relative;overflow:hidden}
.match::before{content:"";position:absolute;left:0;top:0;bottom:0;width:4px;background:var(--line2)}
.match.fin::before{background:var(--ok)}
.match.live::before{background:var(--energy)}
.match.open::before{background:var(--gold)}
.mtop{display:flex;align-items:center;gap:10px;margin-bottom:11px;font-size:11.5px}
.mtop .meta{color:var(--muted);font-weight:600}
.mtop .meta b{color:#c7dccf}
.badge{margin-left:auto;font-size:10.5px;font-weight:800;letter-spacing:.6px;text-transform:uppercase;
  padding:4px 8px;border-radius:6px;border:1px solid var(--line2)}
.badge.fin{background:var(--okdim);color:var(--ok);border-color:transparent}
.badge.live{background:#3a1408;color:var(--energy);border-color:transparent}
.badge.open{background:#322a08;color:var(--gold2);border-color:transparent}
.badge.lock{background:#1b1422;color:#b79ad6;border-color:transparent}
.mrow{display:grid;grid-template-columns:1fr auto 1fr;align-items:center;gap:12px}
.team{display:flex;align-items:center;gap:9px;min-width:0}
.team.away{flex-direction:row-reverse;text-align:right}
.team .fl{width:30px;height:22px;border-radius:4px;object-fit:cover;flex:0 0 auto;
  box-shadow:0 1px 4px rgba(0,0,0,.4);background:#0a1611}
.team .nm{font-weight:700;font-size:15.5px;white-space:nowrap;overflow:hidden;text-overflow:ellipsis}
.team .fl.ph{display:grid;place-items:center;font-size:13px;color:var(--muted);background:#0c1d15;border:1px dashed var(--line2)}
.scorebox{display:flex;align-items:center;gap:7px}
.si{width:46px;height:50px;text-align:center;font-family:'Anton';font-size:26px;color:var(--ink);
  background:#06100c;border:1px solid var(--line2);border-radius:10px;outline:none;padding:0}
.si:focus{border-color:var(--gold);box-shadow:0 0 0 3px rgba(245,197,66,.18)}
.si:disabled{opacity:.85;color:var(--gold2)}
.si.act{background:#0e1f16}
.dash{font-family:'Anton';font-size:22px;color:var(--muted)}
.actual{display:flex;flex-direction:column;align-items:center;gap:2px;min-width:70px}
.actual .sc{font-family:'Anton';font-size:30px;letter-spacing:2px;line-height:1}
.actual .lab{font-size:9px;letter-spacing:1.5px;color:var(--muted);font-weight:800;text-transform:uppercase}
.mfoot{display:flex;align-items:center;gap:8px;margin-top:11px;font-size:12px;color:var(--muted);min-height:18px}
.mfoot .yp{margin-left:auto;font-weight:800;font-size:12px;padding:3px 9px;border-radius:7px}
.yp.exact{background:var(--okdim);color:var(--ok)}
.yp.outc{background:var(--outcdim);color:var(--outc)}
.yp.bad{background:var(--baddim);color:var(--bad)}
.yp.wait{background:#1b2620;color:var(--muted)}
.yourpred{font-weight:700;color:#bcd3c4}
.placeholder-slot{color:#6c8a7c;font-style:italic;font-weight:600}

/* ===== RIGHT: LEADERBOARD ===== */
.panel{background:linear-gradient(180deg,var(--panel),var(--panel2));border:1px solid var(--line);border-radius:var(--r);overflow:hidden}
.panel .ph{padding:14px 16px;border-bottom:1px solid var(--line);display:flex;align-items:center;gap:9px}
.panel .ph h3{margin:0;font-size:16px}
.panel .ph .ico{font-size:18px}
.lbrow{display:flex;align-items:center;gap:11px;padding:11px 16px;border-bottom:1px solid var(--line);cursor:pointer}
.lbrow:hover{background:#12281d}
.lbrow:last-child{border-bottom:none}
.rank{font-family:'Anton';font-size:18px;width:26px;text-align:center;color:var(--muted)}
.rank.g1{color:var(--gold)}.rank.g2{color:#cfd6dd}.rank.g3{color:#d99a5b}
.lbav{width:34px;height:34px;border-radius:50%;display:grid;place-items:center;font-weight:800;font-size:14px;
  background:linear-gradient(160deg,#1e3c2a,#0e2017);border:1px solid var(--line2);color:#cfe3d6}
.lbrow.me .lbav{background:linear-gradient(160deg,var(--gold),#b8860b);color:#241400;border:none}
.lbinfo{flex:1;min-width:0}
.lbinfo .nm{font-weight:700;font-size:14.5px;white-space:nowrap;overflow:hidden;text-overflow:ellipsis}
.lbinfo .st{font-size:11px;color:var(--muted);font-weight:600}
.lbinfo .st .e{color:var(--ok)}.lbinfo .st .o{color:var(--outc)}
.lbpts{font-family:'Anton';font-size:22px;color:var(--gold)}
.lbpts small{font-size:10px;color:var(--muted);font-weight:700;display:block;text-align:right;letter-spacing:1px}

/* scoring mini card */
.scoringcard{padding:15px 16px}
.scoringcard .row{display:flex;align-items:center;gap:11px;padding:9px 0;border-bottom:1px dashed var(--line)}
.scoringcard .row:last-child{border-bottom:none}
.scoringcard .pts{font-family:'Anton';font-size:20px;min-width:62px;text-align:center;border-radius:8px;padding:5px 0}
.pts.p30{background:var(--outcdim);color:var(--outc)}
.pts.p100{background:var(--okdim);color:var(--ok)}
.scoringcard .row .d{font-size:12.5px;color:#c7dccf;font-weight:600}
.scoringcard .row .d b{color:var(--ink)}

/* ===== HOW TO PLAY ===== */
.howto{max-width:760px}
.howto .lead{font-size:15px;line-height:1.6;color:#cbe0d2}
.howto h2{font-size:22px;margin:26px 0 12px}
.bigscore{display:grid;grid-template-columns:1fr 1fr;gap:14px;margin:16px 0}
@media(max-width:560px){.bigscore{grid-template-columns:1fr}}
.bigscore .b{background:linear-gradient(180deg,var(--panel),var(--panel2));border:1px solid var(--line);border-radius:14px;padding:18px}
.bigscore .b .n{font-family:'Anton';font-size:40px}
.bigscore .b.a .n{color:var(--outc)}.bigscore .b.b .n{color:var(--ok)}
.bigscore .b .t{font-weight:800;font-size:14px;margin:4px 0 6px}
.bigscore .b .x{font-size:13px;color:var(--muted);line-height:1.5}
.howto ul{padding-left:18px;line-height:1.8;color:#cbe0d2;font-size:14px}
.note{background:#10201a;border:1px solid var(--line);border-left:3px solid var(--gold);border-radius:10px;padding:13px 15px;font-size:13.5px;color:#cbe0d2;margin-top:14px}

/* ===== ADMIN ===== */
.admin .arow{display:grid;grid-template-columns:1fr 70px 18px 70px 90px;gap:8px;align-items:center;
  background:var(--panel);border:1px solid var(--line);border-radius:12px;padding:10px 12px;margin-bottom:8px}
.admin .arow .nm{font-weight:700;font-size:13.5px}
.admin .arow input{width:100%;height:38px;text-align:center;background:#06100c;border:1px solid var(--line2);
  color:var(--ink);border-radius:8px;font-family:'Anton';font-size:18px}
.admin .arow .tin{font-family:inherit;font-size:13px;text-align:left;padding:0 8px;height:34px}
.admin .teamset{display:grid;grid-template-columns:1fr 1fr;gap:6px;margin-bottom:6px}

/* ===== LOGIN ===== */
.authwrap{min-height:100vh;display:grid;place-items:center;padding:24px}
.authcard{width:100%;max-width:400px;background:linear-gradient(180deg,var(--panel),var(--panel2));
  border:1px solid var(--line);border-radius:20px;padding:30px 26px;box-shadow:0 30px 80px rgba(0,0,0,.5)}
.authcard .lg{display:flex;align-items:center;gap:12px;margin-bottom:6px}
.authcard .lg .t{width:48px;height:48px;border-radius:13px;display:grid;place-items:center;font-size:26px;
  background:linear-gradient(160deg,#1c3a28,#0c1d15);border:1px solid var(--line2)}
.authcard h1{font-size:24px;margin:0;line-height:.95}
.authcard h1 .y{color:var(--gold)}
.authcard .tag{font-size:11px;letter-spacing:2px;color:var(--muted);font-weight:700;margin:2px 0 22px}
.field{margin-bottom:13px}
.field label{display:block;font-size:12px;font-weight:700;color:var(--muted);margin-bottom:6px;letter-spacing:.4px}
.field input{width:100%;height:46px;background:#06100c;border:1px solid var(--line2);color:var(--ink);
  border-radius:11px;padding:0 14px;font-size:15px;outline:none}
.field input:focus{border-color:var(--gold);box-shadow:0 0 0 3px rgba(245,197,66,.16)}
.authbtn{width:100%;height:48px;border:none;border-radius:11px;font-weight:800;font-size:15px;
  background:linear-gradient(160deg,var(--gold),#d9a91f);color:#241400;margin-top:6px}
.authbtn:hover{filter:brightness(1.05)}
.authswitch{text-align:center;margin-top:16px;font-size:13.5px;color:var(--muted)}
.authswitch button{background:none;border:none;color:var(--gold);font-weight:800;font-size:13.5px}
.autherr{background:var(--baddim);color:#ff9aa3;border-radius:10px;padding:10px 12px;font-size:13px;font-weight:600;margin-bottom:14px;display:none}

/* ===== SAVE BAND (slides up from bottom) ===== */
#band{position:fixed;left:50%;bottom:22px;transform:translate(-50%,160%);z-index:80;
  display:flex;align-items:center;gap:12px;background:linear-gradient(160deg,#123c25,#0c2417);
  border:1px solid var(--ok);border-radius:14px;padding:13px 20px;min-width:280px;max-width:90vw;
  box-shadow:0 20px 50px rgba(0,0,0,.5);transition:transform .45s cubic-bezier(.2,.9,.25,1.4)}
#band.show{transform:translate(-50%,0)}
#band .ck{width:30px;height:30px;border-radius:50%;background:var(--ok);color:#04210f;display:grid;place-items:center;font-weight:900;flex:0 0 auto}
#band .tx{font-weight:700;font-size:14px}
#band .tx small{display:block;color:#9cc7ad;font-weight:600;font-size:11.5px;letter-spacing:.5px}
#band.err{background:linear-gradient(160deg,#3a1418,#240d10);border-color:var(--bad)}
#band.err .ck{background:var(--bad);color:#2a0a0d}

/* ===== MODAL ===== */
#modal{position:fixed;inset:0;z-index:90;background:rgba(4,10,7,.7);backdrop-filter:blur(4px);
  display:none;place-items:center;padding:20px}
#modal.show{display:grid}
.mcard{width:100%;max-width:560px;max-height:86vh;overflow:auto;background:linear-gradient(180deg,#0f2419,#0a1812);
  border:1px solid var(--line2);border-radius:20px}
.mcard .mh{position:sticky;top:0;background:#0f2419;padding:18px 20px;border-bottom:1px solid var(--line);
  display:flex;align-items:center;gap:13px;z-index:2}
.mcard .mh .av{width:42px;height:42px;border-radius:50%;display:grid;place-items:center;font-weight:800;
  background:linear-gradient(160deg,var(--gold),#b8860b);color:#241400;font-size:17px}
.mcard .mh h3{margin:0;font-size:19px}
.mcard .mh .s{font-size:12px;color:var(--muted);font-weight:700;margin-top:2px}
.mcard .mh .x{margin-left:auto;background:#13261c;border:1px solid var(--line2);color:var(--ink);
  width:34px;height:34px;border-radius:9px;font-size:18px}
.pgrid{padding:14px 18px 22px}
.pg{display:grid;grid-template-columns:auto 1fr auto auto;gap:10px;align-items:center;padding:10px 12px;
  border-radius:11px;margin-bottom:7px;border:1px solid var(--line)}
.pg.exact{background:var(--okdim);border-color:rgba(43,213,117,.3)}
.pg.outc{background:var(--outcdim);border-color:rgba(70,182,255,.25)}
.pg.bad{background:var(--baddim);border-color:rgba(255,81,96,.25)}
.pg.none{background:#141a17}
.pg .mt{font-size:13px;font-weight:700;white-space:nowrap;overflow:hidden;text-overflow:ellipsis}
.pg .mt small{color:var(--muted);font-weight:600}
.pg .pp{font-family:'Anton';font-size:16px;letter-spacing:1px;color:#cbe0d2}
.pg .aa{font-family:'Anton';font-size:16px;letter-spacing:1px}
.pg .pt{font-weight:800;font-size:13px;min-width:42px;text-align:right}
.pg.exact .pt{color:var(--ok)}.pg.outc .pt{color:var(--outc)}.pg.bad .pt,.pg.none .pt{color:var(--bad)}
.legend{display:flex;gap:14px;flex-wrap:wrap;padding:0 18px 16px;font-size:11.5px;color:var(--muted);font-weight:700}
.legend span{display:inline-flex;align-items:center;gap:6px}
.legend i{width:11px;height:11px;border-radius:3px;display:inline-block}
.lg-e{background:var(--ok)}.lg-o{background:var(--outc)}.lg-b{background:var(--bad)}

.empty{text-align:center;color:var(--muted);padding:50px 20px;font-weight:600}
.setup{max-width:640px;margin:50px auto;background:var(--panel);border:1px solid var(--line);border-radius:16px;padding:26px}
.setup code{background:#06100c;border:1px solid var(--line2);border-radius:6px;padding:2px 6px;font-size:13px}
.loading{display:grid;place-items:center;min-height:60vh;color:var(--muted);font-weight:700;gap:14px}
.spin{width:34px;height:34px;border:3px solid var(--line2);border-top-color:var(--gold);border-radius:50%;animation:sp 1s linear infinite}
@keyframes sp{to{transform:rotate(360deg)}}
.hidden{display:none!important}
</style>
</head>
<body>

<!-- ================= AUTH ================= -->
<div id="authScreen" class="authwrap hidden">
  <div class="authcard">
    <div class="lg"><div class="t">🏆</div>
      <div><h1>DÜNYA KUPASI <span class="y">2026</span></h1></div>
    </div>
    <div class="tag">TAHMİN LİGİ · ARKADAŞLAR ARASI</div>
    <div class="autherr" id="authErr"></div>
    <div class="field"><label>Kullanıcı adı</label>
      <input id="auUser" autocomplete="username" placeholder="ör. uraz" maxlength="24"></div>
    <div class="field"><label>Şifre</label>
      <input id="auPass" type="password" autocomplete="current-password" placeholder="••••••••"></div>
    <button class="authbtn" id="auBtn">Giriş yap</button>
    <div class="authswitch" id="auSwitch">Hesabın yok mu? <button id="auToggle">Kayıt ol</button></div>
  </div>
</div>

<!-- ================= APP ================= -->
<div id="appScreen" class="hidden">
  <div id="ribbon"><div class="tag">⚽ CANLI SKORLAR</div><div class="track" id="ribbonTrack"></div></div>

  <header class="app">
    <div class="brand">
      <div class="trophy">🏆</div>
      <div><h1>DÜNYA KUPASI <span class="y">2026</span></h1>
        <div class="sub">Tahmin Ligi</div></div>
    </div>
    <div class="spacer"></div>
    <button class="btn ghost sm" id="refreshBtn" title="Yenile">⟳ Yenile</button>
    <div class="userchip"><span class="nm" id="meName">—</span>
      <span class="av" id="meAv">?</span>
      <button class="btn sm ghost" id="logoutBtn">Çıkış</button></div>
  </header>

  <nav class="tabs">
    <button data-tab="matches" class="on">Maçlar</button>
    <button data-tab="how">Nasıl Oynanır</button>
    <button data-tab="admin" id="adminTab" class="hidden">Yönetim</button>
  </nav>

  <div class="wrap">
    <main class="col-left">
      <!-- MATCHES -->
      <section id="tab-matches">
        <div class="filters" id="stageFilters"></div>
        <div class="filters" id="groupFilters"></div>
        <div id="matchList"><div class="loading"><div class="spin"></div>Maçlar yükleniyor…</div></div>
      </section>

      <!-- HOW TO -->
      <section id="tab-how" class="howto hidden">
        <h2>Nasıl Oynanır</h2>
        <p class="lead">Her maç için bir skor tahmini yaz (örn. <b style="color:var(--ink)">İspanya 3 – 0 Gana</b>).
          Maç başlamadan önce dilediğin kadar değiştirebilirsin. Maç saati gelince tahmin kilitlenir.</p>

        <div class="bigscore">

function authError(msg){ const e=$("#authErr"); e.textContent=msg; e.style.display=msg?"block":"none"; }
function setRegister(on){
  registerMode=on;
  $("#auBtn").textContent = on?"Kayıt ol ve gir":"Giriş yap";
  $("#auSwitch").innerHTML = on
    ? 'Zaten hesabın var mı? <button id="auToggle">Giriş yap</button>'
    : 'Hesabın yok mu? <button id="auToggle">Kayıt ol</button>';
  $("#auToggle").onclick=()=>setRegister(!registerMode);
  authError("");
}
async function doAuth(){
  authError("");
  const u=$("#auUser").value.trim().toLowerCase().replace(/\s+/g,"");
  const p=$("#auPass").value;
  if(u.length<2) return authError("Kullanıcı adı en az 2 karakter olmalı.");
  if(p.length<6) return authError("Şifre en az 6 karakter olmalı.");
  const email=`${u}@${EMAIL_DOMAIN}`;
  $("#auBtn").disabled=true; $("#auBtn").textContent="Lütfen bekle…";
  try{
    if(registerMode){
      const {data,error}=await sb.auth.signUp({email,password:p});
      if(error) throw error;
      if(data.user){
        const {error:pe}=await sb.from("profiles").insert({id:data.user.id,username:u});
        if(pe && pe.code!=="23505") throw pe;
      }
      // bazı projelerde signUp otomatik login yapar; değilse login dene
      if(!data.session){
        const {error:le}=await sb.auth.signInWithPassword({email,password:p});
        if(le) throw le;
      }
    }else{
      const {error}=await sb.auth.signInWithPassword({email,password:p});
      if(error) throw error;
    }
  }catch(err){
    const msg=(err&&err.message)||"Bir hata oluştu.";
    if(/already registered|already exists/i.test(msg)) authError("Bu kullanıcı adı zaten alınmış. Giriş yapmayı dene.");
    else if(/Invalid login/i.test(msg)) authError("Kullanıcı adı veya şifre hatalı.");
    else if(/confirm/i.test(msg)) authError("E-posta onayı açık görünüyor. Supabase ayarlarından 'Confirm email' kapatılmalı.");
    else authError(msg);
  }finally{
    $("#auBtn").disabled=false; $("#auBtn").textContent=registerMode?"Kayıt ol ve gir":"Giriş yap";
  }
}


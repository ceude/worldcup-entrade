function badgeFor(m){
  if(m.finished) return `<span class="badge fin">Bitti</span>`;
  if(isLive(m))  return `<span class="badge live">● Oynanıyor</span>`;
  if(isLocked(m))return `<span class="badge lock">Kilitli</span>`;
  return `<span class="badge open">Açık</span>`;
}
function teamHTML(name,slot,side){
  if(name){
    const fl=flagUrl(name);
    const flg = fl?`<img class="fl" src="${fl}" alt="" loading="lazy">`:`<span class="fl ph">?</span>`;
    return `<div class="team ${side}">${flg}<span class="nm">${esc(trName(name))}</span></div>`;
  }
  return `<div class="team ${side}"><span class="fl ph">?</span><span class="nm placeholder-slot">${esc(slot||"?")}</span></div>`;
}
function matchCard(m){
  const locked=isLocked(m), fin=m.finished, live=isLive(m);
  const cls = fin?"fin":(live?"live":(locked?"":"open"));
  const pred=predsMine[m.id];
  const meta = m.grp ? `Grup <b>${m.grp}</b>` : `<b>${esc(m.label||STAGE_LABEL[m.stage])}</b>`;

  // orta blok: skor inputları ya da gerçek skor
  let center;
  if(fin){
    center=`<div class="actual"><div class="sc">${m.home_score} – ${m.away_score}</div><div class="lab">Sonuç</div></div>`;
  }else{
    const hv=pred?pred.home:"", av=pred?pred.away:"";
    const dis=locked?"disabled":"";
    const act=pred?"act":"";
    center=`<div class="scorebox">
      <input class="si ${act}" data-m="${m.id}" data-side="h" type="number" min="0" max="99" inputmode="numeric" value="${hv}" ${dis}>
      <span class="dash">–</span>
      <input class="si ${act}" data-m="${m.id}" data-side="a" type="number" min="0" max="99" inputmode="numeric" value="${av}" ${dis}>
    </div>`;
  }

  // alt satır
  let foot="";
  if(fin){
    const g=grade(pred||null,m);
    const yp = pred?`<span class="yourpred">Tahminin: ${pred.home}–${pred.away}</span>`:`<span style="color:var(--muted)">Tahmin yapmadın</span>`;
    let pill="";
    if(g.type==="exact") pill=`<span class="yp exact">SKOR TAM · +100</span>`;
    else if(g.type==="outc") pill=`<span class="yp outc">SONUÇ · +30</span>`;
    else pill=`<span class="yp bad">0 PUAN</span>`;
    foot=`${yp}${pill}`;
  }else if(!m.team_home || !m.team_away){
    foot=`<span style="color:var(--muted)">Takımlar belli olunca tahmine açılacak</span>`;
  }else if(locked){
    foot = pred?`<span class="yourpred">Tahminin: ${pred.home}–${pred.away}</span><span class="yp wait">Sonuç bekleniyor</span>`
               :`<span style="color:var(--muted)">Tahmin yapmadın · kilitlendi</span>`;
  }else{
    foot = pred?`<span class="yourpred">✓ Tahminin: ${pred.home}–${pred.away}</span><span style="margin-left:auto;color:var(--muted)">değiştirebilirsin</span>`
               :`<span style="color:var(--muted)">Skoru yaz, otomatik kaydedilir</span>`;
  }

  return `<div class="match ${cls}">
    <div class="mtop"><span class="meta">${meta}</span>
      <span class="meta">🕑 ${fmtKick(m.kickoff)} <span style="opacity:.6">(DE)</span></span>
      ${badgeFor(m)}</div>
    <div class="mrow">
      ${teamHTML(m.team_home,m.slot_home,"home")}
      ${center}
      ${teamHTML(m.team_away,m.slot_away,"away")}
    </div>
    <div class="mfoot">${foot}</div>
  </div>`;
}
function renderMatches(){
  const list=$("#matchList");
  let ms=matches.filter(m=>m.stage===curStage);
  if(curStage==="group" && curGroup!=="ALL") ms=ms.filter(m=>m.grp===curGroup);
  if(!ms.length){ list.innerHTML=`<div class="empty">Bu sekmede maç yok.</div>`; return; }
  // gün gün grupla
  let html="", lastDay=null;
  ms.forEach(m=>{
    const dk=dayKey(m.kickoff);
    if(dk!==lastDay){ html+=`<div class="dayhdr">${esc(dk)}</div>`; lastDay=dk; }
    html+=matchCard(m);
  });
  list.innerHTML=html;
  bindScoreInputs();
}
function renderStageFilters(){
  const present=new Set(matches.map(m=>m.stage));
  $("#stageFilters").innerHTML = STAGES.filter(s=>present.has(s.k)).map(s=>
    `<button class="pill ${s.k===curStage?"on":""}" data-stage="${s.k}">${s.label}</button>`).join("");
  $("#stageFilters").querySelectorAll(".pill").forEach(b=>b.onclick=()=>{
    curStage=b.dataset.stage; curGroup="ALL"; renderStageFilters(); renderGroupFilters(); renderMatches();
  });
}
function renderGroupFilters(){
  const box=$("#groupFilters");
  if(curStage!=="group"){ box.innerHTML=""; return; }
  const gs=[...new Set(matches.filter(m=>m.grp).map(m=>m.grp))].sort();
  box.innerHTML = `<button class="pill ${curGroup==="ALL"?"on":""}" data-g="ALL">Tüm Gruplar</button>`+
    gs.map(g=>`<button class="pill ${curGroup===g?"on":""}" data-g="${g}">Grup ${g}</button>`).join("");
  box.querySelectorAll(".pill").forEach(b=>b.onclick=()=>{ curGroup=b.dataset.g; renderGroupFilters(); renderMatches(); });
}

/* ====================================================================
   9) Skor girişi → otomatik kaydet → bant
   ==================================================================== */
const saveTimers={};
function bindScoreInputs(){
  $("#matchList").querySelectorAll(".si").forEach(inp=>{
    inp.addEventListener("input",()=>{
      const mid=+inp.dataset.m;
      clearTimeout(saveTimers[mid]);
      saveTimers[mid]=setTimeout(()=>trySave(mid),700);
    });
  });
}
async function trySave(mid){
  const h=$(`.si[data-m="${mid}"][data-side="h"]`);
  const a=$(`.si[data-m="${mid}"][data-side="a"]`);
  if(!h||!a) return;
  if(h.value==="" || a.value==="") return; // ikisi de dolmadan kaydetme
  let hv=Math.max(0,Math.min(99,parseInt(h.value,10)));
  let av=Math.max(0,Math.min(99,parseInt(a.value,10)));
  if(isNaN(hv)||isNaN(av)) return;
  const m=matches.find(x=>x.id===mid);
  if(!m || isLocked(m)) return;
  try{
    const {error}=await sb.from("predictions").upsert(
      {user_id:session.user.id,match_id:mid,home:hv,away:av,updated_at:new Date().toISOString()},
      {onConflict:"user_id,match_id"});
    if(error) throw error;
    predsMine[mid]={user_id:session.user.id,match_id:mid,home:hv,away:av};
    // predsAll içinde güncelle (kendi)
    const i=predsAll.findIndex(p=>p.user_id===session.user.id && p.match_id===mid);
    if(i>=0) predsAll[i]={...predsAll[i],home:hv,away:av}; else predsAll.push({user_id:session.user.id,match_id:mid,home:hv,away:av});
    h.classList.add("act"); a.classList.add("act");
    band(`${trName(m.team_home)} ${hv} – ${av} ${trName(m.team_away)}`,"Tahmin kaydedildi");
  }catch(err){
    band((err&&err.message)||"Kaydedilemedi","Hata",true);
  }
}
let bandTimer=null;
function band(title,sub,isErr){
  const b=$("#band");
  $("#bandTx").innerHTML=`${esc(title)}<small>${esc(sub||"")}</small>`;
  b.classList.toggle("err",!!isErr);
  b.querySelector(".ck").textContent=isErr?"!":"✓";
  b.classList.add("show");
  clearTimeout(bandTimer);
  bandTimer=setTimeout(()=>b.classList.remove("show"),3200);
}


/* ====================================================================
   4) Zaman / kilit yardımcıları (Almanya saati ile gösterim)
   ==================================================================== */
const now = ()=>new Date();
const isLocked = m => !m.team_home || !m.team_away || new Date(m.kickoff) <= now();
const isLive  = m => {
  if(m.finished || !m.team_home || !m.team_away) return false;
  const k=new Date(m.kickoff).getTime(); const n=now().getTime();
  return n>=k && n < k + 2.5*3600*1000;
};
function fmtKick(iso){
  const d=new Date(iso);
  const day=d.toLocaleDateString("tr-TR",{timeZone:TZ,day:"2-digit",month:"short"});
  const tm=d.toLocaleTimeString("tr-TR",{timeZone:TZ,hour:"2-digit",minute:"2-digit"});
  return `${day} · ${tm}`;
}
function dayKey(iso){ return new Date(iso).toLocaleDateString("tr-TR",{timeZone:TZ,weekday:"long",day:"2-digit",month:"long"}); }

/* ====================================================================
   5) PUANLAMA
   ==================================================================== */
function grade(pred, m){
  if(!m.finished || m.home_score==null) return null;
  if(!pred) return {pts:0,type:"none"};
  const exact = pred.home===m.home_score && pred.away===m.away_score;
  if(exact) return {pts:100,type:"exact"};
  const so=Math.sign(pred.home-pred.away), ao=Math.sign(m.home_score-m.away_score);
  if(so===ao) return {pts:30,type:"outc"};
  return {pts:0,type:"bad"};
}
function userTotals(uid){
  let pts=0,exact=0,outc=0,graded=0;
  const byMatch={};
  predsAll.forEach(p=>{ if(p.user_id===uid) byMatch[p.match_id]=p; });
  matches.forEach(m=>{
    if(!m.finished) return;
    const g=grade(byMatch[m.id]||null,m);
    if(!g) return;
    graded++; pts+=g.pts;
    if(g.type==="exact"){exact++;outc++;}
    else if(g.type==="outc"){outc++;}
  });
  return {pts,exact,outc,graded};
}

